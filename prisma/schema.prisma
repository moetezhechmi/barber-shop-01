generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  phone     String?
  image     String?
  role      String   @default("CLIENT")
  createdAt DateTime @default(now())

  shops         Shop[]
  barberProfile Barber?
  appointments  Appointment[]
  reviews       Review[]
  notifications Notification[]
}

model Shop {
  id          String   @id @default(cuid())
  name        String
  description String?
  address     String
  phone       String?
  email       String?
  image       String?
  facebook    String?
  instagram   String?
  tiktok      String?
  isAvailable Boolean  @default(true)
  images      String[] @default([])
  amenities   String[] @default([])
  ownerId     String
  createdAt   DateTime @default(now())

  owner        User           @relation(fields: [ownerId], references: [id])
  barbers      Barber[]
  services     Service[]
  workingHours WorkingHours[]
  appointments Appointment[]
  reviews      Review[]
}

model Barber {
  id         String   @id @default(cuid())
  userId     String   @unique
  shopId     String?
  bio        String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  user         User           @relation(fields: [userId], references: [id])
  shop         Shop?          @relation(fields: [shopId], references: [id])
  workingHours WorkingHours[]
  timeSlots    TimeSlot[]
  appointments Appointment[]
  reviews      Review[]
  gallery      GalleryImage[]
}

model Service {
  id          String   @id @default(cuid())
  shopId      String
  name        String
  description String?
  price       Float
  duration    Int
  createdAt   DateTime @default(now())

  shop         Shop          @relation(fields: [shopId], references: [id])
  appointments Appointment[]
}

model WorkingHours {
  id          String  @id @default(cuid())
  barberId    String?
  shopId      String?
  dayOfWeek   Int
  startTime   String
  endTime     String
  isAvailable Boolean @default(true)

  barber Barber? @relation(fields: [barberId], references: [id])
  shop   Shop?   @relation(fields: [shopId], references: [id])
}

model TimeSlot {
  id        String  @id @default(cuid())
  barberId  String
  date      String
  startTime String
  endTime   String
  isBooked  Boolean @default(false)

  barber Barber @relation(fields: [barberId], references: [id])
}

model Appointment {
  id        String   @id @default(cuid())
  clientId  String
  barberId  String
  shopId    String
  serviceId String
  date      String
  startTime String
  endTime   String
  status    String   @default("PENDING")
  notes     String?
  createdAt DateTime @default(now())

  client  User    @relation(fields: [clientId], references: [id])
  barber  Barber  @relation(fields: [barberId], references: [id])
  shop    Shop    @relation(fields: [shopId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  review  Review?
}

model Review {
  id            String   @id @default(cuid())
  clientId      String
  barberId      String
  shopId        String
  appointmentId String   @unique
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  client      User        @relation(fields: [clientId], references: [id])
  barber      Barber      @relation(fields: [barberId], references: [id])
  shop        Shop        @relation(fields: [shopId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model GalleryImage {
  id        String   @id @default(cuid())
  barberId  String
  url       String
  caption   String?
  createdAt DateTime @default(now())

  barber Barber @relation(fields: [barberId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
